---
import DataBankLayout from './DataBankLayout.astro';
import Infobox from '../components/Infobox.astro';
import type { WikiCollection } from '../content.config';
import { sitePath } from '../lib/sitePath';

interface InfoboxRow {
  label: string;
  value?: string;
}

interface Props {
  title: string;
  description?: string;
  collection: WikiCollection;
  infoboxRows?: InfoboxRow[];
  portraitUrl?: string;
}

const { title, description, collection, infoboxRows = [], portraitUrl } = Astro.props;

const collectionLabels: Record<WikiCollection, string> = {
  characters: 'Characters',
  factions: 'Factions',
  aeons: 'Aeons',
  locations: 'Locations',
  terminology: 'Terminology',
  lightcones: 'Light Cones',
  relics: 'Relics',
};
---

<DataBankLayout
  title={title}
  description={description}
  variant="article"
  category={title}
  backHref={sitePath(`/${collection}/`)}
>
  <article class="entry-panel">
    <nav class="entry-crumb" aria-label="Breadcrumb">
      <a href={sitePath('/')}>Data Bank</a>
      <span class="sep">›</span>
      <a href={sitePath(`/${collection}/`)}>{collectionLabels[collection]}</a>
      <span class="sep">›</span>
      <span>{title}</span>
    </nav>

    <div class="entry-body-wrap">
      {infoboxRows.length > 0 && (
        <Infobox title={title} rows={infoboxRows} imageUrl={portraitUrl} />
      )}
      <div class="article-body">
        <h1>{title}</h1>
        <slot />
      </div>
    </div>
  </article>
</DataBankLayout>
