---
import '../styles/databank.css';
import { site } from '../../site.config';
import Sidebar from '../components/Sidebar.astro';
import { sitePath } from '../lib/sitePath';

interface Props {
  title: string;
  description?: string;
  activeNav?:
    | 'home'
    | 'characters'
    | 'factions'
    | 'locations'
    | 'terminology'
    | 'lightcones'
    | 'relics';
}

const { title, description, activeNav = 'home' } = Astro.props;
const pageTitle = title === site.title ? title : `${title} — ${site.title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? site.tagline} />
    <link rel="icon" type="image/svg+xml" href={sitePath('favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Rajdhani:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="starfield" aria-hidden="true"></div>
    <div class="site-shell">
      <Sidebar activeNav={activeNav} />
      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>
