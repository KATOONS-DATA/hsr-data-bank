---
import DataBankLayout from '../layouts/DataBankLayout.astro';
import { site } from '../../site.config';
import { categories } from '../content.config';
import { getCollection } from 'astro:content';
import { sitePath } from '../lib/sitePath';

const counts = await Promise.all(
  categories.map(async (cat) => {
    const col = cat.id as keyof typeof import('../content.config').collections;
    try {
      const entries = await getCollection(col);
      const published = entries.filter((e) => !e.data.draft && !e.id.startsWith('_'));
      return { ...cat, count: published.length };
    } catch {
      return { ...cat, count: 0 };
    }
  }),
);

/** Orbital positions — tuned to match in-game Data Bank layout. */
const orbitSlots: Record<string, { x: string; y: string; size: string }> = {
  characters: { x: '58%', y: '52%', size: 'large' },
  lightcones: { x: '22%', y: '38%', size: 'medium' },
  factions: { x: '18%', y: '72%', size: 'medium' },
  aeons: { x: '42%', y: '28%', size: 'medium' },
  locations: { x: '38%', y: '18%', size: 'medium' },
  terminology: { x: '78%', y: '22%', size: 'medium' },
  relics: { x: '72%', y: '72%', size: 'medium' },
};
---

<DataBankLayout title={site.title} description={site.tagline} variant="hub">
  <div class="orbital-stage">
    <svg class="orbital-rings" viewBox="0 0 1000 700" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <ellipse cx="500" cy="380" rx="420" ry="280" class="ring ring-1" />
      <ellipse cx="500" cy="380" rx="320" ry="200" class="ring ring-2" />
      <ellipse cx="500" cy="380" rx="220" ry="140" class="ring ring-3" />
      <ellipse cx="500" cy="380" rx="120" ry="75" class="ring ring-4" />
      <circle cx="500" cy="380" r="4" class="ring-node" />
      <circle cx="920" cy="380" r="3" class="ring-node" />
      <circle cx="80" cy="380" r="3" class="ring-node" />
      <circle cx="500" cy="100" r="3" class="ring-node" />
      <circle cx="500" cy="660" r="3" class="ring-node" />
    </svg>

    <nav class="orbital-nav" aria-label="Data Bank categories">
      {
        counts.map((cat) => {
          const slot = orbitSlots[cat.id] ?? { x: '50%', y: '50%', size: 'medium' };
          return (
            <a
              href={sitePath(cat.href)}
              class:list={['orbit-node', `orbit-${slot.size}`]}
              style={`--ox: ${slot.x}; --oy: ${slot.y}`}
            >
              <span class="orbit-icon" aria-hidden="true">
                {cat.id === 'characters' && (
                  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.2">
                    <circle cx="40" cy="40" r="36" />
                    <path d="M28 32c0-6 5-10 12-10s12 4 12 10" />
                    <path d="M22 48c4-8 12-12 18-12s14 4 18 12" />
                    <path d="M52 32c0-6 5-10 12-10" />
                    <path d="M58 48c-4-8-12-12-18-12" />
                    <path d="M40 18l4 8 8 2-6 6 2 8-8-4-8 4 2-8-6-6 8-2z" />
                  </svg>
                )}
                {cat.id === 'lightcones' && (
                  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.2">
                    <rect x="18" y="18" width="44" height="44" rx="2" />
                    <circle cx="40" cy="40" r="14" />
                    <path d="M40 26v28M26 40h28" />
                    <path d="M30 30l20 20M50 30L30 50" />
                  </svg>
                )}
                {cat.id === 'factions' && (
                  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.2">
                    <path d="M40 12l8 16 18 4-12 14 2 18-16-8-16 8 2-18L14 32l18-4z" />
                    <circle cx="40" cy="40" r="28" />
                  </svg>
                )}
                {cat.id === 'aeons' && (
                  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.2">
                    <circle cx="40" cy="40" r="28" />
                    <path d="M40 12v56M12 40h56" />
                    <path d="M20 20l40 40M60 20L20 60" />
                    <circle cx="40" cy="40" r="6" />
                  </svg>
                )}
                {cat.id === 'locations' && (
                  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.2">
                    <path d="M40 14c-12 0-22 10-22 22 0 16 22 34 22 34s22-18 22-34c0-12-10-22-22-22z" />
                    <circle cx="40" cy="36" r="8" />
                  </svg>
                )}
                {cat.id === 'terminology' && (
                  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.2">
                    <rect x="14" y="20" width="28" height="22" rx="3" />
                    <rect x="38" y="32" width="28" height="22" rx="3" />
                    <path d="M22 28h12M22 34h8" />
                    <path d="M46 40h12M46 46h8" />
                  </svg>
                )}
                {cat.id === 'relics' && (
                  <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.2">
                    <circle cx="40" cy="40" r="10" />
                    <circle cx="40" cy="16" r="6" />
                    <circle cx="58" cy="28" r="6" />
                    <circle cx="58" cy="52" r="6" />
                    <circle cx="40" cy="64" r="6" />
                    <circle cx="22" cy="52" r="6" />
                    <circle cx="22" cy="28" r="6" />
                  </svg>
                )}
              </span>
              <span class="orbit-label">{cat.label}</span>
              <span class="orbit-count">{cat.count}</span>
              <span class="orbit-glyphs" aria-hidden="true">◇ ✦ ◈</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</DataBankLayout>
