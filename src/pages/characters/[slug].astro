---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('characters');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const infoboxRows = [
  { label: 'Faction', value: d.faction },
  { label: 'Path', value: d.path },
  { label: 'Rarity', value: d.rarity != null ? String(d.rarity) : undefined },
  { label: 'World', value: d.world },
  { label: 'Status', value: d.status },
  { label: 'Role', value: d.role },
];
---

<ArticleLayout
  title={d.title}
  description={d.description}
  collection="characters"
  infoboxRows={infoboxRows}
>
  <Content />
</ArticleLayout>
