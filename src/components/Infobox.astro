---
interface Row {
  label: string;
  value?: string;
}

interface Props {
  title: string;
  rows: Row[];
}

const { title, rows } = Astro.props;
const visibleRows = rows.filter((row) => row.value && row.value.trim() !== '');
---

{
  visibleRows.length > 0 && (
    <aside class="infobox">
      <div class="infobox-header">{title}</div>
      <table>
        <tbody>
          {visibleRows.map((row) => (
            <tr>
              <th>{row.label}</th>
              <td>{row.value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </aside>
  )
}
