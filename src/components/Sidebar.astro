---
import { site } from '../../site.config';
import { categories } from '../content.config';
import { sitePath } from '../lib/sitePath';

interface Props {
  activeNav:
    | 'home'
    | 'characters'
    | 'factions'
    | 'locations'
    | 'terminology'
    | 'lightcones'
    | 'relics';
}

const { activeNav } = Astro.props;

const navItems = [
  { id: 'home' as const, label: 'Overview', href: sitePath('/') },
  ...categories.map((c) => ({ id: c.id, label: c.label, href: sitePath(c.href) })),
];
---

<aside class="sidebar">
  <div class="sidebar-header">
    <span class="sidebar-logo" aria-hidden="true">◈</span>
    <div class="sidebar-title-block">
      <span class="sidebar-title">{site.title}</span>
      <span class="sidebar-subtitle">{site.tagline}</span>
    </div>
  </div>

  <nav class="sidebar-nav" aria-label="Data Bank categories">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class:list={['nav-item', { 'is-active': activeNav === item.id }]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>

  <div class="sidebar-footer">Archive v1.0</div>
</aside>
