{
  "name": "hsr-data-bank",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "import:game": "node scripts/import-game-data.mjs --type characters",
